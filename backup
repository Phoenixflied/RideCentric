# --- FLIGHTAWARE-STYLE DEEP DATA ENGINE ---
def get_live_flight_details(flight_no):
    details = {
        "status_text": "SCHEDULED",
        "delay_mins": 0,
        "terminal": "TBD",
        "gate": "TBD",
        "baggage": "TBD",
        "aircraft": "UNK",
        "eta": "TBD",
        "accuracy": "N/A"
    }
    
    if not FLIGHT_API_KEY: return details
        
    clean_flight = flight_no.replace(" ", "").upper()
    url = f"https://airlabs.co/api/v9/schedules?api_key={FLIGHT_API_KEY}&flight_iata={clean_flight}"
    
    try:
        req = urllib.request.Request(url, headers={'User-Agent': 'Mozilla/5.0'})
        with urllib.request.urlopen(req, timeout=5) as response:
            data = json.loads(response.read().decode())
            
            if 'response' in data and len(data['response']) > 0:
                f_data = data['response'][0]
                
                # Extract Deep Details
                details["terminal"] = f_data.get('arr_terminal', 'TBD') or 'TBD'
                details["gate"] = f_data.get('arr_gate', 'TBD') or 'TBD'
                details["baggage"] = f_data.get('arr_baggage', 'TBD') or 'TBD'
                details["aircraft"] = f_data.get('aircraft_icao', 'UNK') or 'UNK'
                
                # Extract Estimated Arrival Time (ETA)
                est_time = f_data.get('arr_estimated', f_data.get('arr_time', 'TBD'))
                if est_time != 'TBD' and ' ' in est_time:
                    details["eta"] = est_time.split(' ')[1] # Grabs just the time, not the date
                else:
                    details["eta"] = est_time
                
                delay = f_data.get('delayed')
                status = f_data.get('status')
                
                # Accuracy & Status Logic
                if delay and int(delay) > 0:
                    details["status_text"] = f"DELAYED {delay}m"
                    details["delay_mins"] = int(delay)
                    details["accuracy"] = "98.5% (ADS-B)"
                elif status == "active":
                    details["status_text"] = "EN ROUTE"
                    details["accuracy"] = "98.5% (ADS-B)"
                elif status == "landed":
                    details["status_text"] = "LANDED"
                    details["accuracy"] = "100% (Confirmed)"
                else:
                    details["status_text"] = "ON TIME"
                    details["accuracy"] = "85.0% (Scheduled)"
                    
    except Exception as e:
        print(f"API Error for {clean_flight}: {e}")
        details["status_text"] = "OFFLINE"
        details["accuracy"] = "0% (No Signal)"
        
    return details
# -----------------------------------

def load_db(file_path):
    if os.path.exists(file_path):
        try:
            with open(file_path, "r") as f: 
                data = json.load(f)
                if isinstance(data, dict): return data
        except Exception: pass
    return {}

def save_db(data):
    with open(DB_FILE, "w") as f: json.dump(data, f, indent=4)

if not os.path.exists(DB_FILE): save_db({})

